# 測試環境配置
NODE_ENV=test

# 測試資料庫配置
# 設為 true 使用真實的 PostgreSQL 測試資料庫
# 設為 false 使用 SQLite in-memory 資料庫（更快，適合單元測試）
TEST_USE_REAL_DB=false

# 真實測試資料庫連線資訊（當 TEST_USE_REAL_DB=true 時使用）
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=testuser
TEST_DB_PASS=testpassword
TEST_DB_NAME=test_exam_system

# Piston Judger URL（測試時可以使用 mock 或真實的 judger）
JUDGER_URL=http://localhost:2000

# Judge 限制
JUDGE_CPU_TIME_LIMIT_MS=5000
JUDGE_WALL_TIME_LIMIT_MS=10000
JUDGE_MEMORY_LIMIT_KB=51200
